      "retry_attempts": 3,

      "url": "https://www.newegg.com/p/pl?Order=3&N=100007709%20601469156%20601408872%20601357282%20601469155%20601410971%20601359511&page={page}",

      "selector": ".item-cell",

      "fields": [
        {
          "name": "title",
          "selector": ".item-title",
          "attribute": "text"
        },
        {
          "name": "url",
          "selector": ".item-title",
          "attribute": "href"
        },
        {
          "name": "price",
          "selector": ".price-current",
          "attribute": "text"
        },
        {
          "name": "image_url",
          "selector": ".item-img img",
          "attribute": ["src", "data-src"]
        }
      ],

      "pagination": {
        "type": "page",
        "start": 1,
        "end": 1
      },

      "dedupe_key": "url"
    }    
  ]
}