      "retry_attempts": 3,

      "url": "https://drifthq.com/collections/forced-induction-1?page={page}",

      "render_wait": ".snize-product",

      "selector": ".snize-product",

      "fields": [
          {
            "name": "title",
            "selector": ".snize-title",
            "attribute": "text"
          },
          {
            "name": "price",
            "selector": ".snize-price.money",
            "attribute": "text"
          },
          {
            "name": "description",
            "selector": ".snize-description",
            "attribute": "text"
          },
          {
            "name": "url",
            "selector": "a.snize-view-link",
            "attribute": "href"
          },
          {
            "name": "image_url",
            "selector": "img.snize-item-image",
            "attribute": "src"
          }                
        ],

      "pagination": {
        "type": "page",
        "start": 1,
        "end": 20
      },

      "dedupe_key": "url"
    }                  
  ]
}